{
  "name": "stock-sense",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,yellow \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "npm run build:client",
    "build:client": "npm run build -w client",
    "start:server": "npm run start -w server",
    "start": "node server/index.js",
    "lint": "npm run lint -w client",
    "test:server": "npm run test -w server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
